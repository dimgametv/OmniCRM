<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>OmniFinance | CRM</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; -webkit-tap-highlight-color: transparent; overflow: hidden; }
        .app-container { height: 100dvh; display: flex; flex-direction: column; overflow: hidden; }
        .hidden { display: none !important; }
        
        @keyframes fadeInUp { from { transform: translateY(12px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
        .animate-in { animation: fadeInUp 0.4s ease-out forwards; }
        
        .tab-active { color: #2563eb !important; }
        .tab-active i { stroke-width: 2.5px; }

        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        
        .fab { position: fixed; bottom: 100px; right: 20px; z-index: 50; }
        @keyframes pulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.05); } }
        .fab:hover { animation: pulse 0.5s ease-in-out; }
        
        .progress-bar { background: linear-gradient(90deg, #22c55e 0%, #16a34a 100%); }
        
        @keyframes slideUp { from { transform: translateY(100%); } to { transform: translateY(0); } }
        .modal-slide { animation: slideUp 0.3s ease-out; }
    </style>
</head>
<body class="bg-slate-50 text-slate-900">

    <div id="app" class="app-container">
        
        <section id="view-auth" class="flex-1 flex flex-col items-center justify-center p-8 bg-white">
            <div class="w-full max-w-sm space-y-8 animate-in">
                <div class="text-center">
                    <div class="w-16 h-16 bg-blue-600 rounded-3xl flex items-center justify-center text-white mx-auto mb-6 shadow-xl shadow-blue-100">
                        <i data-lucide="landmark" class="w-8 h-8"></i>
                    </div>
                    <h1 class="text-3xl font-extrabold tracking-tight">OmniFinance</h1>
                    <p class="text-slate-400 mt-2 font-medium">Lending & Capital Management</p>
                </div>
                <div class="space-y-4">
                    <input type="email" placeholder="Email" class="w-full px-5 py-4 rounded-2xl bg-slate-50 border border-slate-100 outline-none focus:ring-2 focus:ring-blue-600 transition-all">
                    <button onclick="handleAuth()" id="login-btn" class="w-full bg-blue-600 text-white py-4 rounded-2xl font-bold shadow-lg active:scale-95 transition-all">Enter Workspace</button>
                </div>
            </div>
        </section>

        <section id="view-main" class="hidden flex-1 flex flex-col overflow-hidden">
            <header class="flex items-center justify-between px-6 py-5 bg-white border-b border-slate-50">
                <div class="flex items-center gap-3">
                    <button id="back-btn" onclick="goBack()" class="hidden w-10 h-10 rounded-xl bg-slate-50 flex items-center justify-center">
                        <i data-lucide="arrow-left" class="w-5 h-5"></i>
                    </button>
                    <div>
                        <p class="text-[10px] font-bold text-blue-600 uppercase tracking-widest">Finance Module</p>
                        <h2 id="app-title" class="text-lg font-bold">Dashboard</h2>
                    </div>
                </div>
                <button onclick="switchTab('profile')" class="w-10 h-10 rounded-full border-2 border-white shadow-sm overflow-hidden bg-slate-100">
                    <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=FinanceManager">
                </button>
            </header>

            <main id="main-content" class="flex-1 overflow-y-auto p-5 no-scrollbar"></main>

            <div id="fab" class="fab hidden">
                <button onclick="toggleFabMenu()" class="w-14 h-14 bg-blue-600 rounded-full shadow-lg shadow-blue-200 flex items-center justify-center text-white active:scale-95 transition-all">
                    <i data-lucide="plus" class="w-6 h-6"></i>
                </button>
                <div id="fab-menu" class="hidden absolute bottom-16 right-0 bg-white rounded-2xl shadow-xl border border-slate-100 overflow-hidden min-w-[180px]">
                    <button onclick="switchTab('borrower-create')" class="w-full p-4 text-left text-sm font-semibold flex items-center gap-3 hover:bg-slate-50">
                        <i data-lucide="user-plus" class="w-4 h-4 text-blue-600"></i> Add Borrower
                    </button>
                    <button onclick="switchTab('loan-create')" class="w-full p-4 text-left text-sm font-semibold flex items-center gap-3 hover:bg-slate-50 border-t border-slate-50">
                        <i data-lucide="file-plus" class="w-4 h-4 text-emerald-600"></i> Create Loan
                    </button>
                    <button onclick="switchTab('payment-entry')" class="w-full p-4 text-left text-sm font-semibold flex items-center gap-3 hover:bg-slate-50 border-t border-slate-50">
                        <i data-lucide="credit-card" class="w-4 h-4 text-purple-600"></i> Add Payment
                    </button>
                </div>
            </div>

            <nav id="bottom-nav" class="flex justify-around items-center p-4 bg-white border-t border-slate-100 pb-8 md:pb-4">
                <button id="tab-dashboard" onclick="switchTab('dashboard')" class="flex flex-col items-center gap-1 text-slate-300">
                    <i data-lucide="layout-grid" class="w-6 h-6"></i>
                    <span class="text-[10px] font-bold">Dashboard</span>
                </button>
                <button id="tab-loans" onclick="switchTab('loans')" class="flex flex-col items-center gap-1 text-slate-300">
                    <i data-lucide="wallet" class="w-6 h-6"></i>
                    <span class="text-[10px] font-bold">Loans</span>
                </button>
                <button id="tab-payments" onclick="switchTab('payments')" class="flex flex-col items-center gap-1 text-slate-300">
                    <i data-lucide="banknote" class="w-6 h-6"></i>
                    <span class="text-[10px] font-bold">Payments</span>
                </button>
            </nav>
        </section>

        <!-- Receipt Modal -->
        <div id="receipt-modal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-end justify-center">
            <div class="bg-white w-full max-w-md rounded-t-3xl p-6 modal-slide">
                <div id="receipt-content"></div>
            </div>
        </div>
    </div>

    <script>
        // State Management
        let state = { 
            tab: 'dashboard', 
            prevTab: null,
            selectedLoanId: null,
            selectedBorrowerId: null
        };

        // Data Storage
        let data = {
            borrowers: [],
            loans: [],
            payments: []
        };

        // Load data from localStorage
        function loadData() {
            const saved = localStorage.getItem('omnifinance_data');
            if (saved) {
                data = JSON.parse(saved);
            } else {
                // Demo data
                data = {
                    borrowers: [
                        { id: 'b1', name: 'Robert Fox', phone: '555-0101', address: '123 Main St' },
                        { id: 'b2', name: 'Darlene Robertson', phone: '555-0102', address: '456 Oak Ave' },
                        { id: 'b3', name: 'Jerome Bell', phone: '555-0103', address: '789 Pine Rd' }
                    ],
                    loans: [
                        { id: 'l1', borrowerId: 'b1', amount: 10000, interest: 12, tenure: 12, emi: 888.49, startDate: '2024-01-15', balance: 7500, status: 'active', nextEmiDate: '2025-01-15' },
                        { id: 'l2', borrowerId: 'b2', amount: 5000, interest: 10, tenure: 6, emi: 858.18, startDate: '2024-06-01', balance: 2500, status: 'active', nextEmiDate: '2025-01-01' },
                        { id: 'l3', borrowerId: 'b3', amount: 15000, interest: 15, tenure: 24, emi: 726.55, startDate: '2024-03-10', balance: 12000, status: 'overdue', nextEmiDate: '2024-12-10' }
                    ],
                    payments: [
                        { id: 'p1', loanId: 'l1', amount: 888.49, date: '2025-01-10', notes: 'January EMI' },
                        { id: 'p2', loanId: 'l2', amount: 858.18, date: '2025-01-08', notes: 'Regular payment' },
                        { id: 'p3', loanId: 'l1', amount: 888.49, date: '2024-12-15', notes: 'December EMI' }
                    ]
                };
                saveData();
            }
        }

        function saveData() {
            localStorage.setItem('omnifinance_data', JSON.stringify(data));
        }

        // Utility Functions
        function generateId() {
            return Date.now().toString(36) + Math.random().toString(36).substr(2);
        }

        function formatCurrency(amount) {
            return '$' + Number(amount).toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
        }

        function formatDate(dateStr) {
            return new Date(dateStr).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
        }

        function getInitials(name) {
            return name.split(' ').map(n => n[0]).join('').toUpperCase().slice(0, 2);
        }

        // Core Business Functions
        function calculateEMI(principal, rate, tenure) {
            const monthlyRate = rate / 12 / 100;
            if (monthlyRate === 0) return principal / tenure;
            const emi = principal * monthlyRate * Math.pow(1 + monthlyRate, tenure) / (Math.pow(1 + monthlyRate, tenure) - 1);
            return Math.round(emi * 100) / 100;
        }

        function createBorrower(name, phone, address) {
            const borrower = { id: generateId(), name, phone, address };
            data.borrowers.push(borrower);
            saveData();
            return borrower;
        }

        function createLoan(borrowerId, amount, interest, tenure, startDate) {
            const emi = calculateEMI(amount, interest, tenure);
            const nextDate = new Date(startDate);
            nextDate.setMonth(nextDate.getMonth() + 1);
            
            const loan = {
                id: generateId(),
                borrowerId,
                amount: Number(amount),
                interest: Number(interest),
                tenure: Number(tenure),
                emi,
                startDate,
                balance: Number(amount),
                status: 'active',
                nextEmiDate: nextDate.toISOString().split('T')[0]
            };
            data.loans.push(loan);
            saveData();
            return loan;
        }

        function addPayment(loanId, amount, date, notes = '') {
            const payment = { id: generateId(), loanId, amount: Number(amount), date, notes };
            data.payments.push(payment);
            
            const loan = data.loans.find(l => l.id === loanId);
            if (loan) {
                loan.balance = Math.max(0, loan.balance - Number(amount));
                if (loan.balance <= 0) {
                    loan.status = 'closed';
                } else {
                    const nextDate = new Date(loan.nextEmiDate);
                    nextDate.setMonth(nextDate.getMonth() + 1);
                    loan.nextEmiDate = nextDate.toISOString().split('T')[0];
                    loan.status = 'active';
                }
            }
            saveData();
            return payment;
        }

        function getBorrower(id) {
            return data.borrowers.find(b => b.id === id);
        }

        function getLoan(id) {
            return data.loans.find(l => l.id === id);
        }

        function getLoanPayments(loanId) {
            return data.payments.filter(p => p.loanId === loanId).sort((a, b) => new Date(b.date) - new Date(a.date));
        }

        function getBorrowerLoans(borrowerId) {
            return data.loans.filter(l => l.borrowerId === borrowerId);
        }

        function getTotalLent() {
            return data.loans.reduce((sum, l) => sum + l.amount, 0);
        }

        function getTotalOutstanding() {
            return data.loans.filter(l => l.status !== 'closed').reduce((sum, l) => sum + l.balance, 0);
        }

        function getTodayCollection() {
            const today = new Date().toISOString().split('T')[0];
            return data.payments.filter(p => p.date === today).reduce((sum, p) => sum + p.amount, 0);
        }

        function getOverdueLoans() {
            const today = new Date();
            return data.loans.filter(l => {
                if (l.status === 'closed') return false;
                const nextEmi = new Date(l.nextEmiDate);
                return nextEmi < today;
            });
        }

        function getOverdueAmount() {
            return getOverdueLoans().reduce((sum, l) => sum + l.emi, 0);
        }

        function getOverdueDays(loan) {
            const today = new Date();
            const nextEmi = new Date(loan.nextEmiDate);
            const diff = Math.floor((today - nextEmi) / (1000 * 60 * 60 * 24));
            return Math.max(0, diff);
        }

        function updateOverdueStatus() {
            const today = new Date();
            data.loans.forEach(loan => {
                if (loan.status === 'closed') return;
                const nextEmi = new Date(loan.nextEmiDate);
                if (nextEmi < today) {
                    loan.status = 'overdue';
                }
            });
            saveData();
        }

        function closeLoan(loanId) {
            const loan = data.loans.find(l => l.id === loanId);
            if (loan) {
                loan.status = 'closed';
                loan.balance = 0;
                saveData();
            }
        }

        // View Management
        function showView(id) {
            document.querySelectorAll('section').forEach(s => s.classList.add('hidden'));
            document.getElementById(`view-${id}`).classList.remove('hidden');
            lucide.createIcons();
        }

        function handleAuth() {
            const btn = document.getElementById('login-btn');
            btn.innerText = 'Accessing Records...';
            setTimeout(() => {
                loadData();
                updateOverdueStatus();
                showView('main');
                switchTab('dashboard');
            }, 800);
        }

        function goBack() {
            if (state.prevTab) {
                switchTab(state.prevTab);
            } else {
                switchTab('dashboard');
            }
        }

        function toggleFabMenu() {
            const menu = document.getElementById('fab-menu');
            menu.classList.toggle('hidden');
        }

        function showReceipt(payment, loan, borrower) {
            const modal = document.getElementById('receipt-modal');
            const content = document.getElementById('receipt-content');
            content.innerHTML = `
                <div class="text-center mb-6">
                    <div class="w-16 h-16 bg-emerald-100 rounded-full flex items-center justify-center mx-auto mb-4">
                        <i data-lucide="check-circle" class="w-8 h-8 text-emerald-600"></i>
                    </div>
                    <h3 class="text-xl font-bold">Payment Successful</h3>
                    <p class="text-slate-400 text-sm mt-1">Transaction completed</p>
                </div>
                <div class="bg-slate-50 rounded-2xl p-4 space-y-3 mb-6">
                    <div class="flex justify-between text-sm">
                        <span class="text-slate-400">Amount</span>
                        <span class="font-bold">${formatCurrency(payment.amount)}</span>
                    </div>
                    <div class="flex justify-between text-sm">
                        <span class="text-slate-400">Borrower</span>
                        <span class="font-semibold">${borrower.name}</span>
                    </div>
                    <div class="flex justify-between text-sm">
                        <span class="text-slate-400">Date</span>
                        <span class="font-semibold">${formatDate(payment.date)}</span>
                    </div>
                    <div class="flex justify-between text-sm">
                        <span class="text-slate-400">Remaining Balance</span>
                        <span class="font-bold text-blue-600">${formatCurrency(loan.balance)}</span>
                    </div>
                </div>
                <button onclick="closeReceipt()" class="w-full py-4 bg-blue-600 text-white rounded-2xl font-bold">Done</button>
            `;
            modal.classList.remove('hidden');
            lucide.createIcons();
        }

        function closeReceipt() {
            document.getElementById('receipt-modal').classList.add('hidden');
        }

        function switchTab(tab) {
            document.getElementById('fab-menu')?.classList.add('hidden');
            
            const isSubPage = ['loan-create', 'loan-details', 'borrower-create', 'payment-entry', 'payment-history', 'profile'].includes(tab);
            
            if (!isSubPage) {
                state.prevTab = null;
            } else if (!['loan-create', 'loan-details', 'borrower-create', 'payment-entry', 'payment-history', 'profile'].includes(state.tab)) {
                state.prevTab = state.tab;
            }
            
            state.tab = tab;
            const container = document.getElementById('main-content');
            const nav = document.getElementById('bottom-nav');
            const title = document.getElementById('app-title');
            const backBtn = document.getElementById('back-btn');
            const fab = document.getElementById('fab');
            
            // Show/hide back button
            if (isSubPage) {
                backBtn.classList.remove('hidden');
                backBtn.classList.add('flex');
            } else {
                backBtn.classList.add('hidden');
                backBtn.classList.remove('flex');
            }

            // FAB visibility
            if (['dashboard', 'loans', 'payments'].includes(tab)) {
                fab.classList.remove('hidden');
            } else {
                fab.classList.add('hidden');
            }

            // Navigation handling
            if (isSubPage) {
                nav.classList.add('hidden');
            } else {
                nav.classList.remove('hidden');
                document.querySelectorAll('nav button').forEach(b => b.classList.remove('tab-active'));
                const activeTab = document.getElementById(`tab-${tab}`);
                if (activeTab) activeTab.classList.add('tab-active');
            }

            // Set titles
            const titles = {
                'dashboard': 'Dashboard',
                'loans': 'Loans',
                'payments': 'Payments',
                'loan-create': 'New Loan',
                'loan-details': 'Loan Details',
                'borrower-create': 'New Borrower',
                'payment-entry': 'Add Payment',
                'payment-history': 'Payment History',
                'profile': 'Settings'
            };
            title.innerText = titles[tab] || 'Dashboard';

            container.innerHTML = `<div class="animate-in">${renderPage(tab)}</div>`;
            lucide.createIcons();
        }

        function renderPage(tab) {
            switch(tab) {
                case 'dashboard': return renderDashboard();
                case 'loans': return renderLoans();
                case 'loan-create': return renderLoanCreate();
                case 'loan-details': return renderLoanDetails();
                case 'borrower-create': return renderBorrowerCreate();
                case 'payments': return renderPayments();
                case 'payment-entry': return renderPaymentEntry();
                case 'payment-history': return renderPaymentHistory();
                case 'profile': return renderProfile();
                default: return renderDashboard();
            }
        }

        function renderDashboard() {
            const overdueLoans = getOverdueLoans();
            const recentPayments = data.payments.slice(-3).reverse();
            const recentLoans = data.loans.slice(-2).reverse();

            return `
                <div class="grid grid-cols-2 gap-3 mb-4">
                    <div class="bg-blue-600 text-white p-5 rounded-3xl shadow-lg shadow-blue-100">
                        <p class="text-[10px] font-bold opacity-70 uppercase">Total Lent</p>
                        <h4 class="text-2xl font-black mt-1">${formatCurrency(getTotalLent())}</h4>
                    </div>
                    <div class="bg-white p-5 rounded-3xl border border-slate-100">
                        <p class="text-[10px] text-slate-400 font-bold uppercase">Outstanding</p>
                        <h4 class="text-2xl font-black mt-1">${formatCurrency(getTotalOutstanding())}</h4>
                    </div>
                    <div class="bg-emerald-50 p-5 rounded-3xl border border-emerald-100">
                        <p class="text-[10px] text-emerald-600 font-bold uppercase">Today's Collection</p>
                        <h4 class="text-2xl font-black mt-1 text-emerald-700">${formatCurrency(getTodayCollection())}</h4>
                    </div>
                    <div class="bg-red-50 p-5 rounded-3xl border border-red-100">
                        <p class="text-[10px] text-red-600 font-bold uppercase">Overdue</p>
                        <h4 class="text-2xl font-black mt-1 text-red-700">${formatCurrency(getOverdueAmount())}</h4>
                    </div>
                </div>

                ${overdueLoans.length > 0 ? `
                <div class="p-4 bg-red-50 border border-red-100 rounded-2xl mb-4 flex items-center gap-3">
                    <div class="w-10 h-10 bg-red-100 rounded-xl flex items-center justify-center">
                        <i data-lucide="alert-triangle" class="w-5 h-5 text-red-600"></i>
                    </div>
                    <div class="flex-1">
                        <p class="font-bold text-sm text-red-700">${overdueLoans.length} Overdue Loan${overdueLoans.length > 1 ? 's' : ''}</p>
                        <p class="text-[10px] text-red-600">Immediate attention required</p>
                    </div>
                    <button onclick="switchTab('payments')" class="text-red-600">
                        <i data-lucide="chevron-right" class="w-5 h-5"></i>
                    </button>
                </div>
                ` : ''}

                <div class="bg-white p-5 rounded-3xl border border-slate-100 mb-4">
                    <h3 class="text-sm font-bold text-slate-400 mb-4">Quick Actions</h3>
                    <div class="grid grid-cols-3 gap-2">
                        <button onclick="switchTab('borrower-create')" class="flex flex-col items-center gap-2 py-4 bg-slate-50 rounded-2xl">
                            <i data-lucide="user-plus" class="w-5 h-5 text-blue-600"></i>
                            <span class="font-bold text-[10px]">Borrower</span>
                        </button>
                        <button onclick="switchTab('loan-create')" class="flex flex-col items-center gap-2 py-4 bg-slate-50 rounded-2xl">
                            <i data-lucide="file-plus" class="w-5 h-5 text-emerald-600"></i>
                            <span class="font-bold text-[10px]">Loan</span>
                        </button>
                        <button onclick="switchTab('payment-entry')" class="flex flex-col items-center gap-2 py-4 bg-slate-50 rounded-2xl">
                            <i data-lucide="credit-card" class="w-5 h-5 text-purple-600"></i>
                            <span class="font-bold text-[10px]">Payment</span>
                        </button>
                    </div>
                </div>

                <div class="space-y-3 mb-4">
                    <h3 class="text-sm font-bold text-slate-400 px-1">Recent Payments</h3>
                    <div class="bg-white rounded-3xl border border-slate-100 divide-y divide-slate-50 overflow-hidden">
                        ${recentPayments.length === 0 ? `
                            <div class="p-6 text-center text-slate-400 text-sm">No payments yet</div>
                        ` : recentPayments.map(p => {
                            const loan = getLoan(p.loanId);
                            const borrower = loan ? getBorrower(loan.borrowerId) : null;
                            return `
                                <div class="p-4 flex justify-between items-center">
                                    <div class="flex items-center gap-3">
                                        <div class="w-10 h-10 bg-emerald-50 text-emerald-600 rounded-xl flex items-center justify-center font-bold text-xs">
                                            ${borrower ? getInitials(borrower.name) : '??'}
                                        </div>
                                        <div>
                                            <p class="font-bold text-sm">${borrower?.name || 'Unknown'}</p>
                                            <p class="text-[10px] text-slate-400">${formatDate(p.date)}</p>
                                        </div>
                                    </div>
                                    <span class="font-bold text-emerald-600">+${formatCurrency(p.amount)}</span>
                                </div>
                            `;
                        }).join('')}
                    </div>
                </div>

                <div class="space-y-3">
                    <h3 class="text-sm font-bold text-slate-400 px-1">Latest Loans</h3>
                    <div class="bg-white rounded-3xl border border-slate-100 divide-y divide-slate-50 overflow-hidden">
                        ${recentLoans.length === 0 ? `
                            <div class="p-6 text-center text-slate-400 text-sm">No loans yet</div>
                        ` : recentLoans.map(l => {
                            const borrower = getBorrower(l.borrowerId);
                            return `
                                <div onclick="state.selectedLoanId='${l.id}';switchTab('loan-details')" class="p-4 flex justify-between items-center cursor-pointer active:bg-slate-50">
                                    <div class="flex items-center gap-3">
                                        <div class="w-10 h-10 bg-blue-50 text-blue-600 rounded-xl flex items-center justify-center font-bold text-xs">
                                            ${borrower ? getInitials(borrower.name) : '??'}
                                        </div>
                                        <div>
                                            <p class="font-bold text-sm">${borrower?.name || 'Unknown'}</p>
                                            <p class="text-[10px] text-slate-400">${formatCurrency(l.amount)} • ${l.tenure}mo</p>
                                        </div>
                                    </div>
