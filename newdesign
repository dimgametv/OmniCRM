        function exportReport(type) {
            let csv = '';
            let filename = '';
            
            if (type === 'loans') {
                csv = 'ID,Borrower,Amount,Interest,Tenure,EMI,Balance,Status,Start Date\n';
                data.loans.forEach(l => {
                    const b = getBorrower(l.borrowerId);
                    csv += `${l.id},${b?.name || ''},${l.amount},${l.interest}%,${l.tenure},${l.emi},${l.balance},${l.status},${l.startDate}\n`;
                });
                filename = 'loans_report.csv';
            } else if (type === 'payments') {
                csv = 'Receipt,Borrower,Amount,Date,Method,Notes\n';
                data.payments.forEach(p => {
                    const l = getLoan(p.loanId);
                    const b = l ? getBorrower(l.borrowerId) : null;
                    csv += `${p.receiptNo},${b?.name || ''},${p.amount},${p.date},${p.method || 'cash'},${p.notes || ''}\n`;
                });
                filename = 'payments_report.csv';
            } else if (type === 'borrowers') {
                csv = 'Name,Phone,Email,Address,Score,Member Since\n';
                data.borrowers.forEach(b => {
                    csv += `${b.name},${b.phone},${b.email || ''},${b.address || ''},${b.score},${b.createdAt}\n`;
                });
                filename = 'borrowers_report.csv';
            }

            const blob = new Blob([csv], { type: 'text/csv' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = filename;
            a.click();
            showToast('Report downloaded successfully', 'success');
        }

        function renderCalendar() {
