<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>OmniFinance | Complete Loan Management System</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        dark: { 50: '#1e293b', 100: '#0f172a', 200: '#020617' }
                    }
                }
            }
        }
    </script>
    <style>
        body { font-family: 'Inter', sans-serif; -webkit-tap-highlight-color: transparent; }
        .app-container { height: 100dvh; display: flex; flex-direction: column; overflow: hidden; }
        .hidden { display: none !important; }
        
        @keyframes fadeInUp { from { transform: translateY(12px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
        @keyframes slideUp { from { transform: translateY(100%); } to { transform: translateY(0); } }
        @keyframes slideRight { from { transform: translateX(-100%); } to { transform: translateX(0); } }
        @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }
        @keyframes bounce { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-5px); } }
        
        .animate-in { animation: fadeInUp 0.3s ease-out forwards; }
        .animate-fade { animation: fadeIn 0.2s ease-out; }
        .animate-slide { animation: slideUp 0.3s ease-out; }
        .animate-slide-right { animation: slideRight 0.3s ease-out; }
        .animate-pulse-slow { animation: pulse 2s ease-in-out infinite; }
        .animate-bounce-slow { animation: bounce 1s ease-in-out infinite; }
        
        .tab-active { color: #2563eb !important; background: #eff6ff; }
        .dark .tab-active { background: #1e3a5f !important; }

        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        
        .custom-scroll::-webkit-scrollbar { width: 6px; height: 6px; }
        .custom-scroll::-webkit-scrollbar-track { background: #f1f5f9; border-radius: 3px; }
        .custom-scroll::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 3px; }
        .custom-scroll::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
        .dark .custom-scroll::-webkit-scrollbar-track { background: #1e293b; }
        .dark .custom-scroll::-webkit-scrollbar-thumb { background: #475569; }
        
        .progress-bar { background: linear-gradient(90deg, #22c55e 0%, #16a34a 100%); }
        .progress-bar-blue { background: linear-gradient(90deg, #3b82f6 0%, #2563eb 100%); }
        .progress-bar-amber { background: linear-gradient(90deg, #f59e0b 0%, #d97706 100%); }
        .progress-bar-red { background: linear-gradient(90deg, #ef4444 0%, #dc2626 100%); }
        
        .card-hover { transition: all 0.2s ease; }
        .card-hover:hover { transform: translateY(-2px); box-shadow: 0 8px 25px -5px rgba(0,0,0,0.1); }
        .dark .card-hover:hover { box-shadow: 0 8px 25px -5px rgba(0,0,0,0.3); }
        
        .row-hover { transition: background 0.15s ease; }
        .row-hover:hover { background: #f8fafc; }
        .dark .row-hover:hover { background: #1e293b; }
        
        .fab { position: fixed; bottom: 100px; right: 20px; z-index: 40; }
        @media (min-width: 1024px) { .fab { bottom: 30px; right: 30px; } }
        
        .sidebar { width: 280px; transition: transform 0.3s ease; }
        @media (max-width: 1023px) {
            .sidebar { position: fixed; left: 0; top: 0; bottom: 0; z-index: 50; transform: translateX(-100%); }
            .sidebar.open { transform: translateX(0); }
        }
        
        .main-content { transition: margin-left 0.3s ease; }
        @media (min-width: 1024px) { .main-content { margin-left: 280px; } }
        
        .toast { animation: slideUp 0.3s ease-out, fadeIn 0.3s ease-out; }
        
        .glass { background: rgba(255,255,255,0.8); backdrop-filter: blur(10px); }
        .dark .glass { background: rgba(15,23,42,0.8); }
        
        .gradient-blue { background: linear-gradient(135deg, #3b82f6 0%, #1d4ed8 100%); }
        .gradient-emerald { background: linear-gradient(135deg, #10b981 0%, #059669 100%); }
        .gradient-purple { background: linear-gradient(135deg, #8b5cf6 0%, #7c3aed 100%); }
        .gradient-amber { background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%); }
        .gradient-rose { background: linear-gradient(135deg, #f43f5e 0%, #e11d48 100%); }
        
        input[type="date"]::-webkit-calendar-picker-indicator { filter: invert(0.5); }
        .dark input[type="date"]::-webkit-calendar-picker-indicator { filter: invert(1); }
        
        @media print {
            .no-print { display: none !important; }
            body { background: white !important; }
        }
    </style>
</head>
<body class="bg-slate-50 text-slate-900 dark:bg-dark-100 dark:text-slate-100">

    <div id="app" class="app-container">
        
        <!-- Auth View -->
        <section id="view-auth" class="flex-1 flex items-center justify-center p-6 bg-gradient-to-br from-blue-600 via-blue-700 to-indigo-800">
            <div class="w-full max-w-md space-y-8 animate-in">
                <div class="bg-white dark:bg-dark-50 rounded-3xl p-8 shadow-2xl">
                    <div class="text-center mb-8">
                        <div class="w-20 h-20 gradient-blue rounded-3xl flex items-center justify-center text-white mx-auto mb-6 shadow-xl">
                            <i data-lucide="landmark" class="w-10 h-10"></i>
                        </div>
                        <h1 class="text-3xl font-extrabold tracking-tight dark:text-white">OmniFinance</h1>
                        <p class="text-slate-400 mt-2">Complete Loan Management System</p>
                    </div>
                    <div class="space-y-4">
                        <div>
                            <label class="text-xs font-bold text-slate-400 uppercase mb-2 block">Email</label>
                            <input type="email" id="auth-email" placeholder="admin@omnifinance.com" value="admin@omnifinance.com" class="w-full px-4 py-4 rounded-2xl bg-slate-50 dark:bg-dark-100 border border-slate-200 dark:border-slate-700 outline-none focus:ring-2 focus:ring-blue-500 transition-all">
                        </div>
                        <div>
                            <label class="text-xs font-bold text-slate-400 uppercase mb-2 block">Password</label>
                            <div class="relative">
                                <input type="password" id="auth-password" placeholder="••••••••" value="admin123" class="w-full px-4 py-4 rounded-2xl bg-slate-50 dark:bg-dark-100 border border-slate-200 dark:border-slate-700 outline-none focus:ring-2 focus:ring-blue-500 transition-all pr-12">
                                <button onclick="togglePassword()" class="absolute right-4 top-4 text-slate-400">
                                    <i data-lucide="eye" class="w-5 h-5" id="eye-icon"></i>
                                </button>
                            </div>
                        </div>
                        <div class="flex items-center justify-between text-sm">
                            <label class="flex items-center gap-2 cursor-pointer">
                                <input type="checkbox" checked class="w-4 h-4 rounded border-slate-300 text-blue-600 focus:ring-blue-500">
                                <span class="text-slate-600 dark:text-slate-400">Remember me</span>
                            </label>
                            <a href="#" class="text-blue-600 font-semibold hover:underline">Forgot password?</a>
                        </div>
                        <button onclick="handleAuth()" id="login-btn" class="w-full gradient-blue text-white py-4 rounded-2xl font-bold shadow-lg hover:shadow-xl active:scale-[0.98] transition-all flex items-center justify-center gap-2">
                            <span>Sign In</span>
                            <i data-lucide="arrow-right" class="w-5 h-5"></i>
                        </button>
                    </div>
                    <div class="mt-6 pt-6 border-t border-slate-100 dark:border-slate-700">
                        <p class="text-center text-sm text-slate-400">Demo credentials pre-filled. Just click Sign In!</p>
                    </div>
                </div>
                <div class="text-center text-white/60 text-sm">
                    <p>Secure • Fast • Reliable</p>
                </div>
            </div>
        </section>

        <!-- Main View -->
        <section id="view-main" class="hidden flex-1 flex overflow-hidden">
            
            <!-- Sidebar Overlay (Mobile) -->
            <div id="sidebar-overlay" class="hidden fixed inset-0 bg-black/50 z-40 lg:hidden" onclick="toggleSidebar()"></div>
            
            <!-- Sidebar -->
            <aside id="sidebar" class="sidebar bg-white dark:bg-dark-50 border-r border-slate-100 dark:border-slate-800 flex flex-col">
                <div class="p-6 border-b border-slate-100 dark:border-slate-800">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 gradient-blue rounded-xl flex items-center justify-center text-white shadow-lg">
                            <i data-lucide="landmark" class="w-5 h-5"></i>
                        </div>
                        <div>
                            <h1 class="font-bold text-lg dark:text-white">OmniFinance</h1>
                            <p class="text-[10px] text-slate-400">Loan Management</p>
                        </div>
                        <button onclick="toggleSidebar()" class="lg:hidden ml-auto p-2 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg">
                            <i data-lucide="x" class="w-5 h-5"></i>
                        </button>
                    </div>
                </div>
                
                <div class="p-4">
                    <div class="relative">
                        <i data-lucide="search" class="absolute left-3 top-3 w-4 h-4 text-slate-400"></i>
                        <input type="text" id="global-search" placeholder="Search..." oninput="handleGlobalSearch()" class="w-full pl-10 pr-4 py-3 rounded-xl bg-slate-50 dark:bg-dark-100 border border-slate-100 dark:border-slate-700 text-sm outline-none focus:ring-2 focus:ring-blue-100">
                    </div>
                </div>
                
                <nav class="flex-1 px-4 space-y-1 overflow-y-auto custom-scroll">
                    <p class="text-[10px] font-bold text-slate-400 uppercase px-3 py-2">Main</p>
                    <button onclick="switchTab('dashboard')" data-tab="dashboard" class="nav-btn w-full flex items-center gap-3 px-3 py-3 rounded-xl text-left font-medium text-sm text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 transition-all">
                        <i data-lucide="layout-grid" class="w-5 h-5"></i> Dashboard
                    </button>
                    <button onclick="switchTab('loans')" data-tab="loans" class="nav-btn w-full flex items-center gap-3 px-3 py-3 rounded-xl text-left font-medium text-sm text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 transition-all">
                        <i data-lucide="wallet" class="w-5 h-5"></i> Loans
                        <span class="ml-auto text-[10px] font-bold bg-blue-100 dark:bg-blue-900 text-blue-600 dark:text-blue-300 px-2 py-0.5 rounded-full" id="loan-count">0</span>
                    </button>
                    <button onclick="switchTab('borrowers')" data-tab="borrowers" class="nav-btn w-full flex items-center gap-3 px-3 py-3 rounded-xl text-left font-medium text-sm text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 transition-all">
                        <i data-lucide="users" class="w-5 h-5"></i> Borrowers
                    </button>
                    <button onclick="switchTab('payments')" data-tab="payments" class="nav-btn w-full flex items-center gap-3 px-3 py-3 rounded-xl text-left font-medium text-sm text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 transition-all">
                        <i data-lucide="banknote" class="w-5 h-5"></i> Payments
                    </button>
                    <button onclick="switchTab('collections')" data-tab="collections" class="nav-btn w-full flex items-center gap-3 px-3 py-3 rounded-xl text-left font-medium text-sm text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 transition-all">
                        <i data-lucide="calendar-check" class="w-5 h-5"></i> Collections
                        <span class="ml-auto text-[10px] font-bold bg-red-100 dark:bg-red-900 text-red-600 dark:text-red-300 px-2 py-0.5 rounded-full" id="overdue-count">0</span>
                    </button>
                    
                    <p class="text-[10px] font-bold text-slate-400 uppercase px-3 py-2 mt-4">Analytics</p>
                    <button onclick="switchTab('reports')" data-tab="reports" class="nav-btn w-full flex items-center gap-3 px-3 py-3 rounded-xl text-left font-medium text-sm text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 transition-all">
                        <i data-lucide="bar-chart-3" class="w-5 h-5"></i> Reports
                    </button>
                    <button onclick="switchTab('calendar')" data-tab="calendar" class="nav-btn w-full flex items-center gap-3 px-3 py-3 rounded-xl text-left font-medium text-sm text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 transition-all">
                        <i data-lucide="calendar" class="w-5 h-5"></i> Calendar
                    </button>
                    
                    <p class="text-[10px] font-bold text-slate-400 uppercase px-3 py-2 mt-4">Management</p>
                    <button onclick="switchTab('agents')" data-tab="agents" class="nav-btn w-full flex items-center gap-3 px-3 py-3 rounded-xl text-left font-medium text-sm text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 transition-all">
                        <i data-lucide="user-cog" class="w-5 h-5"></i> Agents
                    </button>
                    <button onclick="switchTab('documents')" data-tab="documents" class="nav-btn w-full flex items-center gap-3 px-3 py-3 rounded-xl text-left font-medium text-sm text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 transition-all">
                        <i data-lucide="folder" class="w-5 h-5"></i> Documents
                    </button>
                    <button onclick="switchTab('communications')" data-tab="communications" class="nav-btn w-full flex items-center gap-3 px-3 py-3 rounded-xl text-left font-medium text-sm text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 transition-all">
                        <i data-lucide="message-square" class="w-5 h-5"></i> Communications
                    </button>
                    <button onclick="switchTab('activity')" data-tab="activity" class="nav-btn w-full flex items-center gap-3 px-3 py-3 rounded-xl text-left font-medium text-sm text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 transition-all">
                        <i data-lucide="activity" class="w-5 h-5"></i> Activity Log
                    </button>
                </nav>
                
                <div class="p-4 border-t border-slate-100 dark:border-slate-800">
                    <button onclick="switchTab('settings')" class="w-full flex items-center gap-3 px-3 py-3 rounded-xl hover:bg-slate-50 dark:hover:bg-slate-800 transition-all">
                        <div class="w-10 h-10 rounded-xl bg-slate-100 dark:bg-slate-800 overflow-hidden">
                            <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=Admin" class="w-full h-full">
                        </div>
                        <div class="flex-1 text-left">
                            <p class="font-semibold text-sm dark:text-white" id="current-user-name">Finance Admin</p>
                            <p class="text-[10px] text-slate-400">Administrator</p>
                        </div>
                        <i data-lucide="settings" class="w-4 h-4 text-slate-400"></i>
                    </button>
                </div>
            </aside>

            <!-- Main Content Area -->
            <div class="main-content flex-1 flex flex-col overflow-hidden bg-slate-50 dark:bg-dark-100">
                <!-- Header -->
                <header class="flex items-center justify-between px-4 lg:px-8 py-4 bg-white dark:bg-dark-50 border-b border-slate-100 dark:border-slate-800 no-print">
                    <div class="flex items-center gap-3">
                        <button onclick="toggleSidebar()" class="lg:hidden w-10 h-10 rounded-xl bg-slate-50 dark:bg-slate-800 flex items-center justify-center hover:bg-slate-100 dark:hover:bg-slate-700 transition-all">
                            <i data-lucide="menu" class="w-5 h-5"></i>
                        </button>
                        <button id="back-btn" onclick="goBack()" class="hidden w-10 h-10 rounded-xl bg-slate-50 dark:bg-slate-800 items-center justify-center hover:bg-slate-100 dark:hover:bg-slate-700 transition-all">
                            <i data-lucide="arrow-left" class="w-5 h-5"></i>
                        </button>
                        <div>
                            <h2 id="page-title" class="text-xl font-bold dark:text-white">Dashboard</h2>
                            <p id="page-subtitle" class="text-xs text-slate-400">Welcome back!</p>
                        </div>
                    </div>
                    <div class="flex items-center gap-2">
                        <!-- Offline Indicator -->
                        <div id="offline-badge" class="hidden items-center gap-2 px-3 py-1.5 bg-amber-100 dark:bg-amber-900 text-amber-700 dark:text-amber-300 rounded-lg text-xs font-semibold">
                            <span class="w-2 h-2 bg-amber-500 rounded-full animate-pulse-slow"></span>
                            Offline
                        </div>
                        <!-- Dark Mode Toggle -->
                        <button onclick="toggleDarkMode()" class="w-10 h-10 rounded-xl bg-slate-50 dark:bg-slate-800 flex items-center justify-center hover:bg-slate-100 dark:hover:bg-slate-700 transition-all">
                            <i data-lucide="moon" class="w-5 h-5 dark:hidden"></i>
                            <i data-lucide="sun" class="w-5 h-5 hidden dark:block"></i>
                        </button>
                        <!-- Notifications -->
                        <button onclick="switchTab('notifications')" class="w-10 h-10 rounded-xl bg-slate-50 dark:bg-slate-800 flex items-center justify-center hover:bg-slate-100 dark:hover:bg-slate-700 transition-all relative">
                            <i data-lucide="bell" class="w-5 h-5"></i>
                            <span id="notif-badge" class="absolute -top-1 -right-1 w-5 h-5 bg-red-500 text-white text-[10px] font-bold rounded-full flex items-center justify-center">0</span>
                        </button>
                        <!-- Quick Add -->
                        <button onclick="openQuickAdd()" class="hidden sm:flex items-center gap-2 px-4 py-2.5 gradient-blue text-white rounded-xl font-semibold text-sm hover:shadow-lg transition-all">
                            <i data-lucide="plus" class="w-4 h-4"></i>
                            <span>Quick Add</span>
                        </button>
                    </div>
                </header>

                <!-- Main Content -->
                <main id="main-content" class="flex-1 overflow-y-auto p-4 lg:p-8 custom-scroll"></main>
                
                <!-- Mobile Bottom Navigation -->
                <nav id="bottom-nav" class="lg:hidden flex justify-around items-center p-3 bg-white dark:bg-dark-50 border-t border-slate-100 dark:border-slate-800 pb-6 no-print">
                    <button onclick="switchTab('dashboard')" data-tab="dashboard" class="mobile-nav-btn flex flex-col items-center gap-1 text-slate-400 p-2 rounded-xl transition-all">
                        <i data-lucide="layout-grid" class="w-5 h-5"></i>
                        <span class="text-[10px] font-bold">Home</span>
                    </button>
                    <button onclick="switchTab('loans')" data-tab="loans" class="mobile-nav-btn flex flex-col items-center gap-1 text-slate-400 p-2 rounded-xl transition-all">
                        <i data-lucide="wallet" class="w-5 h-5"></i>
                        <span class="text-[10px] font-bold">Loans</span>
                    </button>
                    <button onclick="openQuickAdd()" class="w-14 h-14 -mt-8 gradient-blue text-white rounded-2xl shadow-lg flex items-center justify-center">
                        <i data-lucide="plus" class="w-6 h-6"></i>
                    </button>
                    <button onclick="switchTab('payments')" data-tab="payments" class="mobile-nav-btn flex flex-col items-center gap-1 text-slate-400 p-2 rounded-xl transition-all">
                        <i data-lucide="banknote" class="w-5 h-5"></i>
                        <span class="text-[10px] font-bold">Payments</span>
                    </button>
                    <button onclick="switchTab('reports')" data-tab="reports" class="mobile-nav-btn flex flex-col items-center gap-1 text-slate-400 p-2 rounded-xl transition-all">
                        <i data-lucide="bar-chart-3" class="w-5 h-5"></i>
                        <span class="text-[10px] font-bold">Reports</span>
                    </button>
                </nav>
            </div>
        </section>

        <!-- Modal System -->
        <div id="modal-overlay" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4 animate-fade">
            <div id="modal-container" class="bg-white dark:bg-dark-50 w-full max-w-lg max-h-[90vh] rounded-3xl overflow-hidden animate-slide flex flex-col">
                <div id="modal-header" class="flex items-center justify-between p-5 border-b border-slate-100 dark:border-slate-800">
                    <h3 id="modal-title" class="font-bold text-lg dark:text-white">Modal Title</h3>
                    <button onclick="closeModal()" class="w-8 h-8 rounded-lg bg-slate-100 dark:bg-slate-800 flex items-center justify-center hover:bg-slate-200 dark:hover:bg-slate-700">
                        <i data-lucide="x" class="w-4 h-4"></i>
                    </button>
                </div>
                <div id="modal-content" class="flex-1 overflow-y-auto p-5 custom-scroll"></div>
            </div>
        </div>

        <!-- Toast Container -->
        <div id="toast-container" class="fixed bottom-24 lg:bottom-8 left-4 right-4 lg:left-auto lg:right-8 lg:w-96 z-50 space-y-2 pointer-events-none"></div>

        <!-- Quick Add Panel -->
        <div id="quick-add-panel" class="hidden fixed inset-0 z-50">
            <div class="absolute inset-0 bg-black/50" onclick="closeQuickAdd()"></div>
            <div class="absolute bottom-0 left-0 right-0 bg-white dark:bg-dark-50 rounded-t-3xl p-6 animate-slide max-h-[80vh] overflow-y-auto">
                <div class="w-12 h-1 bg-slate-200 dark:bg-slate-700 rounded-full mx-auto mb-6"></div>
                <h3 class="font-bold text-xl mb-6 dark:text-white">Quick Actions</h3>
                <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
                    <button onclick="closeQuickAdd();switchTab('borrower-create')" class="flex flex-col items-center gap-3 p-5 bg-blue-50 dark:bg-blue-900/30 rounded-2xl hover:bg-blue-100 dark:hover:bg-blue-900/50 transition-all">
                        <div class="w-12 h-12 bg-blue-500 rounded-xl flex items-center justify-center text-white">
                            <i data-lucide="user-plus" class="w-6 h-6"></i>
                        </div>
                        <span class="font-semibold text-sm dark:text-white">New Borrower</span>
                    </button>
                    <button onclick="closeQuickAdd();switchTab('loan-create')" class="flex flex-col items-center gap-3 p-5 bg-emerald-50 dark:bg-emerald-900/30 rounded-2xl hover:bg-emerald-100 dark:hover:bg-emerald-900/50 transition-all">
                        <div class="w-12 h-12 bg-emerald-500 rounded-xl flex items-center justify-center text-white">
                            <i data-lucide="file-plus" class="w-6 h-6"></i>
                        </div>
                        <span class="font-semibold text-sm dark:text-white">Create Loan</span>
                    </button>
                    <button onclick="closeQuickAdd();switchTab('payment-entry')" class="flex flex-col items-center gap-3 p-5 bg-purple-50 dark:bg-purple-900/30 rounded-2xl hover:bg-purple-100 dark:hover:bg-purple-900/50 transition-all">
                        <div class="w-12 h-12 bg-purple-500 rounded-xl flex items-center justify-center text-white">
                            <i data-lucide="credit-card" class="w-6 h-6"></i>
                        </div>
                        <span class="font-semibold text-sm dark:text-white">Add Payment</span>
                    </button>
                    <button onclick="closeQuickAdd();switchTab('communications')" class="flex flex-col items-center gap-3 p-5 bg-amber-50 dark:bg-amber-900/30 rounded-2xl hover:bg-amber-100 dark:hover:bg-amber-900/50 transition-all">
                        <div class="w-12 h-12 bg-amber-500 rounded-xl flex items-center justify-center text-white">
                            <i data-lucide="send" class="w-6 h-6"></i>
                        </div>
                        <span class="font-semibold text-sm dark:text-white">Send Reminder</span>
                    </button>
                </div>
                <button onclick="closeQuickAdd()" class="w-full mt-6 py-4 bg-slate-100 dark:bg-slate-800 rounded-2xl font-semibold text-slate-600 dark:text-slate-300">Cancel</button>
            </div>
        </div>

        <!-- Search Results Panel -->
        <div id="search-panel" class="hidden fixed inset-0 z-50">
            <div class="absolute inset-0 bg-black/50" onclick="closeSearchPanel()"></div>
            <div class="absolute top-0 left-0 right-0 lg:left-[280px] bg-white dark:bg-dark-50 p-4 lg:p-6 animate-slide max-h-[70vh] overflow-y-auto shadow-xl">
                <div class="flex items-center justify-between mb-4">
                    <h3 class="font-bold text-lg dark:text-white">Search Results</h3>
                    <button onclick="closeSearchPanel()" class="w-8 h-8 rounded-lg bg-slate-100 dark:bg-slate-800 flex items-center justify-center">
                        <i data-lucide="x" class="w-4 h-4"></i>
                    </button>
                </div>
                <div id="search-results" class="space-y-2"></div>
            </div>
        </div>
    </div>

    <script>
        // ==================== STATE & DATA ====================
        let state = {
            tab: 'dashboard',
            prevTab: null,
            selectedLoanId: null,
            selectedBorrowerId: null,
            selectedAgentId: null,
            darkMode: localStorage.getItem('darkMode') === 'true',
            currentUser: { id: 'u1', name: 'Finance Admin', role: 'admin', email: 'admin@omnifinance.com' }
        };

        let data = {
            borrowers: [],
            loans: [],
            payments: [],
            agents: [],
            documents: [],
            activities: [],
            communications: [],
            settings: { currency: '$', interestType: 'reducing', lateFee: 2, gracePeriod: 5 }
        };

        // ==================== INITIALIZATION ====================
        function init() {
            loadData();
            if (state.darkMode) document.documentElement.classList.add('dark');
            updateOnlineStatus();
            window.addEventListener('online', updateOnlineStatus);
            window.addEventListener('offline', updateOnlineStatus);
            lucide.createIcons();
        }

        function loadData() {
            const saved = localStorage.getItem('omnifinance_data_v2');
            if (saved) {
                data = JSON.parse(saved);
            } else {
                generateDemoData();
            }
        }

        function saveData() {
            localStorage.setItem('omnifinance_data_v2', JSON.stringify(data));
        }

        function generateDemoData() {
            const names = ['Robert Fox', 'Darlene Robertson', 'Jerome Bell', 'Sarah Johnson', 'Michael Chen', 'Emily Davis', 'James Wilson', 'Lisa Anderson', 'David Martinez', 'Jennifer Taylor'];
            const loanTypes = ['personal', 'business', 'gold', 'vehicle', 'home', 'education'];
            
            // Generate Borrowers
            data.borrowers = names.map((name, i) => ({
                id: `b${i+1}`,
                name,
                phone: `555-010${i+1}`,
                email: `${name.toLowerCase().replace(' ', '.')}@email.com`,
                address: `${100 + i} Main Street, City ${i+1}`,
                idType: ['aadhaar', 'pan', 'passport'][i % 3],
                idNumber: `ID${String(i+1).padStart(8, '0')}`,
                score: Math.floor(Math.random() * 50) + 50,
                createdAt: new Date(2024, i % 12, (i % 28) + 1).toISOString().split('T')[0],
                guarantor: i % 3 === 0 ? { name: names[(i+1) % names.length], phone: `555-020${i+1}`, relation: 'Friend' } : null,
                notes: ''
            }));

            // Generate Loans
            data.loans = [];
            for (let i = 0; i < 15; i++) {
                const borrower = data.borrowers[i % data.borrowers.length];
                const amount = [5000, 10000, 15000, 20000, 25000, 50000][i % 6];
                const interest = [10, 12, 15, 18][i % 4];
                const tenure = [6, 12, 18, 24][i % 4];
                const emi = calculateEMI(amount, interest, tenure);
                const startDate = new Date(2024, (i % 6) + 1, (i % 28) + 1);
                const nextDate = new Date(startDate);
                nextDate.setMonth(nextDate.getMonth() + Math.floor(Math.random() * 3) + 1);
                const paidMonths = Math.floor(Math.random() * Math.min(6, tenure));
                const balance = Math.max(0, amount - (paidMonths * emi * 0.7));
                const status = balance <= 0 ? 'closed' : (nextDate < new Date() ? 'overdue' : 'active');

                data.loans.push({
                    id: `l${i+1}`,
                    borrowerId: borrower.id,
                    amount,
                    interest,
                    interestType: ['reducing', 'flat'][i % 2],
                    tenure,
                    emi,
                    startDate: startDate.toISOString().split('T')[0],
                    endDate: new Date(startDate.getFullYear(), startDate.getMonth() + tenure, startDate.getDate()).toISOString().split('T')[0],
                    balance: Math.round(balance),
                    status,
                    nextEmiDate: nextDate.toISOString().split('T')[0],
                    type: loanTypes[i % loanTypes.length],
                    collateral: i % 4 === 0 ? { type: 'gold', description: '10g Gold Chain', value: amount * 1.5 } : null,
                    agentId: `a${(i % 3) + 1}`,
                    lateFee: 0,
                    processingFee: amount * 0.02,
                    notes: ''
                });
            }

            // Generate Payments
            data.payments = [];
            data.loans.forEach((loan, li) => {
                const numPayments = Math.floor(Math.random() * 4) + 1;
                for (let i = 0; i < numPayments; i++) {
                    const payDate = new Date(loan.startDate);
                    payDate.setMonth(payDate.getMonth() + i + 1);
                    if (payDate > new Date()) continue;
                    data.payments.push({
                        id: `p${li}_${i}`,
                        loanId: loan.id,
                        amount: loan.emi + (Math.random() > 0.8 ? Math.floor(Math.random() * 500) : 0),
                        date: payDate.toISOString().split('T')[0],
                        method: ['cash', 'upi', 'bank', 'cheque'][Math.floor(Math.random() * 4)],
                        notes: ['Monthly EMI', 'Advance payment', 'Regular payment'][Math.floor(Math.random() * 3)],
                        receivedBy: `a${(li % 3) + 1}`,
                        receiptNo: `RCP${String(li * 10 + i + 1).padStart(6, '0')}`
                    });
                }
            });

            // Generate Agents
            data.agents = [
                { id: 'a1', name: 'John Smith', phone: '555-1001', email: 'john@omnifinance.com', role: 'collector', area: 'North Zone', active: true, target: 50000, collected: 35000 },
                { id: 'a2', name: 'Mary Johnson', phone: '555-1002', email: 'mary@omnifinance.com', role: 'collector', area: 'South Zone', active: true, target: 45000, collected: 42000 },
                { id: 'a3', name: 'Peter Williams', phone: '555-1003', email: 'peter@omnifinance.com', role: 'manager', area: 'All Zones', active: true, target: 100000, collected: 78000 }
            ];

            // Generate Activity Log
            data.activities = [];
            const actions = ['Created loan', 'Added payment', 'Updated borrower', 'Sent reminder', 'Generated report'];
            for (let i = 0; i < 20; i++) {
                const d = new Date();
                d.setHours(d.getHours() - i * 3);
                data.activities.push({
                    id: `act${i}`,
                    action: actions[i % actions.length],
                    details: `Action performed on record #${i + 1}`,
                    userId: 'u1',
                    userName: 'Finance Admin',
                    timestamp: d.toISOString(),
                    type: ['loan', 'payment', 'borrower', 'system'][i % 4]
                });
            }

            // Communications
            data.communications = [
                { id: 'c1', type: 'sms', to: 'Robert Fox', phone: '555-0101', message: 'Your EMI of $888 is due tomorrow.', status: 'sent', sentAt: new Date().toISOString() },
                { id: 'c2', type: 'whatsapp', to: 'Darlene Robertson', phone: '555-0102', message: 'Payment reminder: $858 due on Jan 15.', status: 'delivered', sentAt: new Date(Date.now() - 86400000).toISOString() }
            ];

            saveData();
        }

        // ==================== UTILITY FUNCTIONS ====================
        function generateId() {
            return Date.now().toString(36) + Math.random().toString(36).substr(2, 9);
        }

        function formatCurrency(amount) {
            return (data.settings?.currency || '$') + Number(amount || 0).toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
        }

        function formatDate(dateStr) {
            if (!dateStr) return '-';
            return new Date(dateStr).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
        }

        function formatDateTime(dateStr) {
            if (!dateStr) return '-';
            return new Date(dateStr).toLocaleString('en-US', { month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' });
        }

        function getInitials(name) {
            if (!name) return '??';
            return name.split(' ').map(n => n[0]).join('').toUpperCase().slice(0, 2);
        }

        function getAvatarColor(name) {
            const colors = [
                'bg-blue-100 text-blue-600 dark:bg-blue-900 dark:text-blue-300',
                'bg-emerald-100 text-emerald-600 dark:bg-emerald-900 dark:text-emerald-300',
                'bg-purple-100 text-purple-600 dark:bg-purple-900 dark:text-purple-300',
                'bg-amber-100 text-amber-600 dark:bg-amber-900 dark:text-amber-300',
                'bg-rose-100 text-rose-600 dark:bg-rose-900 dark:text-rose-300',
                'bg-cyan-100 text-cyan-600 dark:bg-cyan-900 dark:text-cyan-300'
            ];
            return colors[(name || '').charCodeAt(0) % colors.length];
        }

        function calculateEMI(principal, rate, tenure, type = 'reducing') {
            principal = Number(principal);
            rate = Number(rate);
            tenure = Number(tenure);
            if (type === 'flat') {
                const interest = (principal * rate * tenure) / (12 * 100);
                return Math.round((principal + interest) / tenure * 100) / 100;
            }
            const monthlyRate = rate / 12 / 100;
            if (monthlyRate === 0) return Math.round(principal / tenure * 100) / 100;
            const emi = principal * monthlyRate * Math.pow(1 + monthlyRate, tenure) / (Math.pow(1 + monthlyRate, tenure) - 1);
            return Math.round(emi * 100) / 100;
        }

        function getOverdueDays(loan) {
            if (!loan.nextEmiDate) return 0;
            const diff = Math.floor((new Date() - new Date(loan.nextEmiDate)) / (1000 * 60 * 60 * 24));
            return Math.max(0, diff);
        }

        function updateOnlineStatus() {
            const badge = document.getElementById('offline-badge');
            if (navigator.onLine) {
                badge?.classList.add('hidden');
                badge?.classList.remove('flex');
            } else {
                badge?.classList.remove('hidden');
                badge?.classList.add('flex');
            }
        }

        // ==================== DATA FUNCTIONS ====================
        function getBorrower(id) { return data.borrowers.find(b => b.id === id); }
        function getLoan(id) { return data.loans.find(l => l.id === id); }
        function getAgent(id) { return data.agents.find(a => a.id === id); }
        function getLoanPayments(loanId) { return data.payments.filter(p => p.loanId === loanId).sort((a, b) => new Date(b.date) - new Date(a.date)); }
        function getBorrowerLoans(borrowerId) { return data.loans.filter(l => l.borrowerId === borrowerId); }
        
        function getStats() {
            const loans = data.loans;
            const payments = data.payments;
            const today = new Date().toISOString().split('T')[0];
            const monthStart = new Date(new Date().getFullYear(), new Date().getMonth(), 1).toISOString().split('T')[0];
            
            return {
                totalLent: loans.reduce((s, l) => s + l.amount, 0),
                totalOutstanding: loans.filter(l => l.status !== 'closed').reduce((s, l) => s + l.balance, 0),
                todayCollection: payments.filter(p => p.date === today).reduce((s, p) => s + p.amount, 0),
                monthCollection: payments.filter(p => p.date >= monthStart).reduce((s, p) => s + p.amount, 0),
                overdueAmount: loans.filter(l => l.status === 'overdue').reduce((s, l) => s + l.emi, 0),
                activeLoans: loans.filter(l => l.status === 'active').length,
                overdueLoans: loans.filter(l => l.status === 'overdue').length,
                closedLoans: loans.filter(l => l.status === 'closed').length,
                totalBorrowers: data.borrowers.length,
                totalPayments: payments.length,
                interestEarned: payments.reduce((s, p) => s + p.amount, 0) - loans.filter(l => l.status === 'closed').reduce((s, l) => s + l.amount, 0)
            };
        }

        function getOverdueLoans() {
            return data.loans.filter(l => l.status !== 'closed' && new Date(l.nextEmiDate) < new Date());
        }

        // ==================== CRUD OPERATIONS ====================
        function createBorrower(formData) {
            const borrower = {
                id: generateId(),
                ...formData,
                score: 70,
                createdAt: new Date().toISOString().split('T')[0]
            };
            data.borrowers.push(borrower);
            logActivity('Created borrower', `Added new borrower: ${formData.name}`, 'borrower');
            saveData();
            showToast('Borrower added successfully', 'success');
            return borrower;
        }

        function createLoan(formData) {
            const emi = calculateEMI(formData.amount, formData.interest, formData.tenure, formData.interestType);
            const startDate = new Date(formData.startDate);
            const nextDate = new Date(startDate);
            nextDate.setMonth(nextDate.getMonth() + 1);
            
            const loan = {
                id: generateId(),
                ...formData,
                amount: Number(formData.amount),
                interest: Number(formData.interest),
                tenure: Number(formData.tenure),
                emi,
                balance: Number(formData.amount),
                status: 'active',
                nextEmiDate: nextDate.toISOString().split('T')[0],
                endDate: new Date(startDate.getFullYear(), startDate.getMonth() + Number(formData.tenure), startDate.getDate()).toISOString().split('T')[0],
                lateFee: 0,
                processingFee: Number(formData.amount) * 0.02
            };
            data.loans.push(loan);
            logActivity('Created loan', `New loan of ${formatCurrency(loan.amount)} for ${getBorrower(loan.borrowerId)?.name}`, 'loan');
            saveData();
            showToast('Loan created successfully', 'success');
            return loan;
        }

        function addPayment(formData) {
            const loan = getLoan(formData.loanId);
            if (!loan) return null;

            const payment = {
                id: generateId(),
                ...formData,
                amount: Number(formData.amount),
                receiptNo: `RCP${String(data.payments.length + 1).padStart(6, '0')}`,
                receivedBy: state.currentUser.id
            };
            data.payments.push(payment);

            // Update loan
            loan.balance = Math.max(0, loan.balance - Number(formData.amount));
            if (loan.balance <= 0) {
                loan.status = 'closed';
            } else {
                const nextDate = new Date(loan.nextEmiDate);
                nextDate.setMonth(nextDate.getMonth() + 1);
                loan.nextEmiDate = nextDate.toISOString().split('T')[0];
                loan.status = new Date(loan.nextEmiDate) < new Date() ? 'overdue' : 'active';
            }

            logActivity('Added payment', `Payment of ${formatCurrency(formData.amount)} received for loan`, 'payment');
            saveData();
            return payment;
        }

        function closeLoan(loanId) {
            const loan = getLoan(loanId);
            if (loan) {
                loan.status = 'closed';
                loan.balance = 0;
                logActivity('Closed loan', `Loan ${loanId} marked as closed`, 'loan');
                saveData();
                showToast('Loan closed successfully', 'success');
            }
        }

        function logActivity(action, details, type = 'system') {
            data.activities.unshift({
                id: generateId(),
                action,
                details,
                userId: state.currentUser.id,
                userName: state.currentUser.name,
                timestamp: new Date().toISOString(),
                type
            });
            if (data.activities.length > 100) data.activities.pop();
        }

        // ==================== UI FUNCTIONS ====================
        function showView(id) {
            document.querySelectorAll('#app > section').forEach(s => s.classList.add('hidden'));
            document.getElementById(`view-${id}`)?.classList.remove('hidden');
            lucide.createIcons();
        }

        function togglePassword() {
            const input = document.getElementById('auth-password');
            const icon = document.getElementById('eye-icon');
            if (input.type === 'password') {
                input.type = 'text';
                icon.setAttribute('data-lucide', 'eye-off');
            } else {
                input.type = 'password';
                icon.setAttribute('data-lucide', 'eye');
            }
            lucide.createIcons();
        }

        function handleAuth() {
            const btn = document.getElementById('login-btn');
            btn.innerHTML = '<i data-lucide="loader-2" class="w-5 h-5 animate-spin"></i> Signing in...';
            lucide.createIcons();
            
            setTimeout(() => {
                logActivity('User login', 'Admin logged in successfully', 'system');
                showView('main');
                switchTab('dashboard');
                showToast('Welcome back, ' + state.currentUser.name + '!', 'success');
            }, 1000);
        }

        function toggleSidebar() {
            const sidebar = document.getElementById('sidebar');
            const overlay = document.getElementById('sidebar-overlay');
            sidebar.classList.toggle('open');
            overlay.classList.toggle('hidden');
        }

        function toggleDarkMode() {
            state.darkMode = !state.darkMode;
            document.documentElement.classList.toggle('dark', state.darkMode);
            localStorage.setItem('darkMode', state.darkMode);
            showToast(state.darkMode ? 'Dark mode enabled' : 'Light mode enabled', 'info');
        }

        function openQuickAdd() {
            document.getElementById('quick-add-panel').classList.remove('hidden');
        }

        function closeQuickAdd() {
            document.getElementById('quick-add-panel').classList.add('hidden');
        }

        function showModal(title, content, size = 'md') {
            const sizes = { sm: 'max-w-sm', md: 'max-w-lg', lg: 'max-w-2xl', xl: 'max-w-4xl', full: 'max-w-6xl' };
            document.getElementById('modal-title').textContent = title;
            document.getElementById('modal-content').innerHTML = content;
            document.getElementById('modal-container').className = `bg-white dark:bg-dark-50 w-full ${sizes[size]} max-h-[90vh] rounded-3xl overflow-hidden animate-slide flex flex-col`;
            document.getElementById('modal-overlay').classList.remove('hidden');
            lucide.createIcons();
        }

        function closeModal() {
            document.getElementById('modal-overlay').classList.add('hidden');
        }

        function showToast(message, type = 'info') {
            const container = document.getElementById('toast-container');
            const colors = {
                success: 'bg-emerald-500',
                error: 'bg-red-500',
                warning: 'bg-amber-500',
                info: 'bg-blue-500'
            };
            const icons = {
                success: 'check-circle',
                error: 'x-circle',
                warning: 'alert-triangle',
                info: 'info'
            };
            
            const toast = document.createElement('div');
            toast.className = `toast ${colors[type]} text-white px-4 py-3 rounded-xl shadow-lg flex items-center gap-3 pointer-events-auto`;
            toast.innerHTML = `
                <i data-lucide="${icons[type]}" class="w-5 h-5 flex-shrink-0"></i>
                <span class="flex-1 text-sm font-medium">${message}</span>
                <button onclick="this.parentElement.remove()" class="hover:bg-white/20 rounded p-1">
                    <i data-lucide="x" class="w-4 h-4"></i>
                </button>
            `;
            container.appendChild(toast);
            lucide.createIcons();
            
            setTimeout(() => toast.remove(), 4000);
        }

        function goBack() {
            if (state.prevTab) switchTab(state.prevTab);
            else switchTab('dashboard');
        }

        function handleGlobalSearch() {
            const query = document.getElementById('global-search').value.toLowerCase().trim();
            if (query.length < 2) {
                closeSearchPanel();
                return;
            }

            const results = [];
            
            data.borrowers.filter(b => b.name.toLowerCase().includes(query) || b.phone.includes(query))
                .slice(0, 5)
                .forEach(b => results.push({ type: 'borrower', item: b, title: b.name, subtitle: b.phone }));
            
            data.loans.filter(l => {
                const borrower = getBorrower(l.borrowerId);
                return borrower?.name.toLowerCase().includes(query) || l.id.includes(query);
            }).slice(0, 5)
                .forEach(l => {
                    const borrower = getBorrower(l.borrowerId);
                    results.push({ type: 'loan', item: l, title: `Loan - ${borrower?.name}`, subtitle: formatCurrency(l.amount) });
                });

            if (results.length > 0) {
                showSearchResults(results);
            } else {
                closeSearchPanel();
            }
        }

        function showSearchResults(results) {
            const panel = document.getElementById('search-panel');
            const container = document.getElementById('search-results');
            
            container.innerHTML = results.map(r => `
                <button onclick="closeSearchPanel();${r.type === 'borrower' ? `state.selectedBorrowerId='${r.item.id}';switchTab('borrower-details')` : `state.selectedLoanId='${r.item.id}';switchTab('loan-details')`}" 
                    class="w-full flex items-center gap-3 p-3 rounded-xl hover:bg-slate-50 dark:hover:bg-slate-800 text-left transition-all">
                    <div class="w-10 h-10 ${getAvatarColor(r.title)} rounded-xl flex items-center justify-center font-bold text-sm">
                        <i data-lucide="${r.type === 'borrower' ? 'user' : 'wallet'}" class="w-5 h-5"></i>
                    </div>
                    <div class="flex-1 min-w-0">
                        <p class="font-semibold text-sm truncate dark:text-white">${r.title}</p>
                        <p class="text-xs text-slate-400 truncate">${r.subtitle}</p>
                    </div>
                    <span class="text-[10px] font-bold px-2 py-1 rounded-lg bg-slate-100 dark:bg-slate-800 text-slate-500 uppercase">${r.type}</span>
                </button>
            `).join('');
            
            panel.classList.remove('hidden');
            lucide.createIcons();
        }

        function closeSearchPanel() {
            document.getElementById('search-panel').classList.add('hidden');
        }

        // ==================== TAB NAVIGATION ====================
        function switchTab(tab) {
            closeQuickAdd();
            closeSearchPanel();
            if (window.innerWidth < 1024) toggleSidebar();
            
            const subPages = ['loan-create', 'loan-details', 'borrower-create', 'borrower-details', 'payment-entry', 'settings', 'notifications', 'agent-details'];
            const isSubPage = subPages.includes(tab);
            
            if (!isSubPage && !subPages.includes(state.tab)) state.prevTab = null;
            else if (!isSubPage) state.prevTab = null;
            else if (!subPages.includes(state.tab)) state.prevTab = state.tab;
            
            state.tab = tab;
            
            // Update navigation
            document.querySelectorAll('.nav-btn, .mobile-nav-btn').forEach(btn => {
                btn.classList.remove('tab-active');
                if (btn.dataset.tab === tab) btn.classList.add('tab-active');
            });

            // Update header
            const backBtn = document.getElementById('back-btn');
            backBtn.classList.toggle('hidden', !isSubPage);
            backBtn.classList.toggle('flex', isSubPage);
            
            // Update bottom nav visibility
            document.getElementById('bottom-nav').classList.toggle('hidden', isSubPage);

            // Update counts
            document.getElementById('loan-count').textContent = data.loans.filter(l => l.status !== 'closed').length;
            document.getElementById('overdue-count').textContent = getOverdueLoans().length;
            document.getElementById('notif-badge').textContent = getOverdueLoans().length;

            // Render page
            const container = document.getElementById('main-content');
            container.innerHTML = `<div class="animate-in w-full">${renderPage(tab)}</div>`;
            container.scrollTop = 0;
            
            // Update titles
            updatePageTitle(tab);
            
            lucide.createIcons();
            
            // Initialize charts if needed
            if (tab === 'dashboard' || tab === 'reports') {
                setTimeout(initCharts, 100);
            }
        }

        function updatePageTitle(tab) {
            const titles = {
                'dashboard': ['Dashboard', 'Overview of your business'],
                'loans': ['Loans', `${data.loans.length} total loans`],
                'borrowers': ['Borrowers', `${data.borrowers.length} registered borrowers`],
                'payments': ['Payments', `${data.payments.length} transactions`],
                'collections': ['Collections', 'Pending and upcoming EMIs'],
                'reports': ['Reports & Analytics', 'Business insights'],
