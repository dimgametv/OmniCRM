        function updatePaymentLoanInfo() {
            const loanId = document.getElementById('payment-loan').value;
            const infoDiv = document.getElementById('payment-loan-info');
            
            if (loanId) {
                const loan = getLoan(loanId);
                const borrower = getBorrower(loan.borrowerId);
                
                infoDiv.classList.remove('hidden');
                document.getElementById('loan-info-name').textContent = borrower?.name || 'Unknown';
                document.getElementById('loan-info-id').textContent = loan.id.slice(-8).toUpperCase();
                document.getElementById('loan-info-emi').textContent = formatCurrency(loan.emi);
                document.getElementById('loan-info-balance').textContent = formatCurrency(loan.balance);
                document.getElementById('loan-info-due').textContent = formatDate(loan.nextEmiDate);
                document.getElementById('payment-amount').value = loan.emi;
            } else {
                infoDiv.classList.add('hidden');
            }
        }

        function selectPaymentMethod(method) {
            document.querySelectorAll('.payment-method-btn').forEach(btn => {
                const isSelected = btn.dataset.method === method;
                btn.classList.toggle('bg-blue-50', isSelected);
                btn.classList.toggle('dark:bg-blue-900/30', isSelected);
                btn.classList.toggle('border-blue-500', isSelected);
                btn.classList.toggle('bg-slate-50', !isSelected);
                btn.classList.toggle('dark:bg-slate-800', !isSelected);
                btn.classList.toggle('border-transparent', !isSelected);
            });
            document.getElementById('payment-method').value = method;
        }

        function submitPayment() {
            const loanId = document.getElementById('payment-loan').value;
            const amount = document.getElementById('payment-amount').value;
            const date = document.getElementById('payment-date').value;
            const method = document.getElementById('payment-method').value;
            const notes = document.getElementById('payment-notes').value;

            if (!loanId || !amount || !date) {
                showToast('Please fill all required fields', 'error');
                return;
            }

            const payment = addPayment({ loanId, amount, date, method, notes });
            const loan = getLoan(loanId);
            const borrower = getBorrower(loan.borrowerId);

            showPaymentReceipt(payment, loan, borrower);
            state.selectedLoanId = null;
        }

