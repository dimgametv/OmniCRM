        function updateEmiPreview() {
            const amount = Number(document.getElementById('loan-amount')?.value) || 0;
            const interest = Number(document.getElementById('loan-interest')?.value) || 0;
            const tenure = Number(document.getElementById('loan-tenure')?.value) || 0;
            const type = document.getElementById('loan-interest-type')?.value || 'reducing';

            if (amount && interest && tenure) {
                const emi = calculateEMI(amount, interest, tenure, type);
                const total = emi * tenure;
                const totalInterest = total - amount;

                document.getElementById('emi-preview').classList.remove('hidden');
                document.getElementById('emi-amount').textContent = formatCurrency(emi);
                document.getElementById('total-interest').textContent = formatCurrency(totalInterest);
                document.getElementById('total-payable').textContent = formatCurrency(total);
            }
        }

        function toggleCollateral() {
            const hasCollateral = document.getElementById('has-collateral').checked;
            document.getElementById('collateral-fields').classList.toggle('hidden', !hasCollateral);
        }

        function submitLoan() {
            const borrowerId = document.getElementById('loan-borrower').value;
            const amount = document.getElementById('loan-amount').value;
            const interest = document.getElementById('loan-interest').value;
            const tenure = document.getElementById('loan-tenure').value;
            const startDate = document.getElementById('loan-start').value;

            if (!borrowerId || !amount || !interest || !tenure || !startDate) {
                showToast('Please fill all required fields', 'error');
                return;
            }

            const formData = {
                borrowerId,
                amount,
                interest,
                interestType: document.getElementById('loan-interest-type').value,
                tenure,
                startDate,
                type: document.getElementById('loan-type').value,
                agentId: document.getElementById('loan-agent').value,
                notes: document.getElementById('loan-notes').value
            };

            if (document.getElementById('has-collateral').checked) {
                formData.collateral = {
                    type: document.getElementById('collateral-type').value,
                    description: document.getElementById('collateral-desc').value,
                    value: Number(document.getElementById('collateral-value').value)
                };
            }

            createLoan(formData);
            switchTab('loans');
        }

