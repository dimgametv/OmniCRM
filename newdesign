        function sendBulkReminders() {
            const overdueLoans = getOverdueLoans();
            const channel = document.getElementById('bulk-channel').value;
            
            overdueLoans.forEach(l => {
                const b = getBorrower(l.borrowerId);
                data.communications.push({
                    id: generateId(),
                    type: channel,
                    to: b.name,
                    phone: b.phone,
                    message: 'Payment reminder sent',
                    status: 'sent',
                    sentAt: new Date().toISOString(),
                    loanId: l.id
                });
            });
            
            saveData();
            closeModal();
            showToast(`Reminders sent to ${overdueLoans.length} borrowers`, 'success');
            switchTab('communications');
        }

