                                <i data-lucide="download" class="w-4 h-4 text-blue-600"></i>
                                <span class="dark:text-white">Export All Data (JSON)</span>
                            </button>
                            <button onclick="document.getElementById('import-file').click()" class="w-full py-3 px-4 bg-slate-50 dark:bg-slate-800 rounded-xl font-semibold text-sm flex items-center gap-3 hover:bg-slate-100 dark:hover:bg-slate-700 transition-all">
                                <i data-lucide="upload" class="w-4 h-4 text-emerald-600"></i>
                                <span class="dark:text-white">Import Data</span>
                            </button>
                            <input type="file" id="import-file" accept=".json" class="hidden" onchange="importData(this)">
                            <button onclick="showResetConfirm()" class="w-full py-3 px-4 bg-red-50 dark:bg-red-900/30 rounded-xl font-semibold text-sm flex items-center gap-3 hover:bg-red-100 dark:hover:bg-red-900/50 transition-all text-red-600">
                                <i data-lucide="trash-2" class="w-4 h-4"></i>
                                <span>Reset All Data</span>
                            </button>
                        </div>
                    </div>

                    <!-- Logout -->
                    <button onclick="logout()" class="w-full py-4 bg-slate-100 dark:bg-slate-800 rounded-2xl font-bold flex items-center justify-center gap-2 hover:bg-slate-200 dark:hover:bg-slate-700 transition-all">
                        <i data-lucide="log-out" class="w-5 h-5 text-slate-500"></i>
                        <span class="dark:text-white">Sign Out</span>
                    </button>
                </div>
            `;
        }

        function exportAllData() {
            const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `omnifinance_backup_${new Date().toISOString().split('T')[0]}.json`;
            a.click();
            showToast('Data exported successfully', 'success');
        }

        function importData(input) {
            const file = input.files[0];
            if (!file) return;
            
            const reader = new FileReader();
            reader.onload = (e) => {
                try {
                    const imported = JSON.parse(e.target.result);
                    data = imported;
                    saveData();
                    switchTab('dashboard');
                    showToast('Data imported successfully', 'success');
                } catch (err) {
                    showToast('Invalid file format', 'error');
                }
            };
            reader.readAsText(file);
        }

        function showResetConfirm() {
            showModal('Reset All Data?', `
                <div class="text-center">
                    <div class="w-16 h-16 bg-red-100 dark:bg-red-900/50 rounded-full flex items-center justify-center mx-auto mb-4">
                        <i data-lucide="alert-triangle" class="w-8 h-8 text-red-600"></i>
                    </div>
                    <p class="text-slate-400 mb-6">This will delete all borrowers, loans, and payments. This action cannot be undone.</p>
                    <div class="flex gap-3">
                        <button onclick="closeModal()" class="flex-1 py-3 bg-slate-100 dark:bg-slate-800 rounded-xl font-semibold">Cancel</button>
                        <button onclick="resetAllData()" class="flex-1 py-3 bg-red-600 text-white rounded-xl font-semibold">Reset</button>
                    </div>
                </div>
            `, 'sm');
        }

        function resetAllData() {
            localStorage.removeItem('omnifinance_data_v2');
            location.reload();
        }

        function logout() {
            location.reload();
        }

        // ==================== CHARTS ====================
        function initCharts() {
            // Collection Chart
            const collectionCtx = document.getElementById('collectionChart');
            if (collectionCtx) {
                const monthlyData = {};
                data.payments.forEach(p => {
                    const month = p.date.substring(0, 7);
                    monthlyData[month] = (monthlyData[month] || 0) + p.amount;
                });
                
                const labels = Object.keys(monthlyData).slice(-6);
                const values = labels.map(l => monthlyData[l] || 0);

                new Chart(collectionCtx, {
                    type: 'line',
                    data: {
                        labels: labels.map(l => {
                            const d = new Date(l + '-01');
                            return d.toLocaleDateString('en-US', { month: 'short' });
                        }),
                        datasets: [{
                            label: 'Collection',
                            data: values,
                            borderColor: '#3b82f6',
                            backgroundColor: 'rgba(59, 130, 246, 0.1)',
                            fill: true,
                            tension: 0.4,
                            pointRadius: 4,
                            pointBackgroundColor: '#3b82f6'
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { display: false } },
                        scales: {
                            y: { beginAtZero: true, grid: { color: state.darkMode ? '#334155' : '#f1f5f9' } },
                            x: { grid: { display: false } }
                        }
                    }
                });
            }

            // Loan Type Chart
            const loanTypeCtx = document.getElementById('loanTypeChart');
            if (loanTypeCtx) {
                const typeData = {};
                data.loans.forEach(l => {
                    typeData[l.type] = (typeData[l.type] || 0) + 1;
                });

                new Chart(loanTypeCtx, {
                    type: 'doughnut',
                    data: {
                        labels: Object.keys(typeData).map(t => t.charAt(0).toUpperCase() + t.slice(1)),
                        datasets: [{
                            data: Object.values(typeData),
                            backgroundColor: ['#3b82f6', '#10b981', '#f59e0b', '#8b5cf6', '#ef4444', '#06b6d4'],
                            borderWidth: 0
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { position: 'bottom', labels: { padding: 20, usePointStyle: true } }
                        },
                        cutout: '60%'
                    }
                });
            }
        }

        // ==================== EVENT LISTENERS ====================
        document.getElementById('modal-overlay').addEventListener('click', (e) => {
            if (e.target.id === 'modal-overlay') closeModal();
        });

        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') {
                closeModal();
                closeQuickAdd();
                closeSearchPanel();
            }
        });

        // Initialize
        init();
    </script>
</body>
</html>
